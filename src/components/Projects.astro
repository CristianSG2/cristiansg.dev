---
---

<section id="proyectos">
  <div class="container">
    <span class="section-label">Proyectos</span>
    <h2 class="section-title">Lo que construyo</h2>

    <div class="projects-list">
    <div class="project-card">
      <!-- Gradient top border -->
      <div class="card-accent" aria-hidden="true"></div>

      <div class="card-body">
        <div class="project-header">
          <div>
            <span class="project-type mono">Proyecto personal en producción</span>
            <h3 class="project-name">ReadOn</h3>
            <p class="project-tagline">Letterboxd, pero para libros.</p>
          </div>
          <div class="project-links">
            <a
              href="https://readon.cristiansg.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-sm"
            >
              Demo en vivo ↗
            </a>
            <a
              href="https://github.com/CristianSG2/ReadOn"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost btn-sm"
            >
              GitHub ↗
            </a>
          </div>
        </div>

        <p class="project-description">
          Aplicación web de seguimiento y reseña de lecturas con autenticación propia, gestión de
          usuarios, integración con la Google Books API, sistema de temas Catppuccin
          (Mocha&nbsp;dark&nbsp;/&nbsp;Latte&nbsp;light), control de estado de lectura, ratings y
          reseñas, tests automatizados y seeders de demo.
        </p>

        <div class="project-tech">
          <span>Laravel 11</span>
          <span>PHP 8.2</span>
          <span>PostgreSQL</span>
          <span>Blade</span>
          <span>SCSS + Vite</span>
          <span>Docker / DDEV</span>
          <span>Google Books API</span>
        </div>

        <div class="highlights">
          <div class="highlight">
            <span class="mono num">01</span>
            <span>Sistema de temas Catppuccin con toggle dark/light persistente</span>
          </div>
          <div class="highlight">
            <span class="mono num">02</span>
            <span>Autenticación manual sin dependencias externas — sin Jetstream ni Breeze</span>
          </div>
          <div class="highlight">
            <span class="mono num">03</span>
            <span>Integración completa con Google Books API para búsqueda y metadatos</span>
          </div>
          <div class="highlight">
            <span class="mono num">04</span>
            <span>Tests automatizados y seeders de datos de demo incluidos</span>
          </div>
        </div>
      </div>
    </div>

    <div class="project-card">
      <div class="card-accent" aria-hidden="true"></div>

      <div class="card-body">
        <div class="project-header">
          <div>
            <span class="project-type mono">Proyecto personal en producción</span>
            <h3 class="project-name">Ledgr</h3>
            <p class="project-tagline">Tus finanzas, sin hojas de cálculo.</p>
          </div>
          <div class="project-links">
            <a
              href="https://ledgr.cristiansg.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-sm"
            >
              Demo en vivo ↗
            </a>
            <a
              href="https://github.com/CristianSG2/ledgr"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost btn-sm"
            >
              GitHub ↗
            </a>
          </div>
        </div>

        <p class="project-description">
          Gestor de finanzas personales full-stack: cuentas de usuario con JWT, CRUD de
          transacciones, presupuestos mensuales con alertas por color, gastos e ingresos
          recurrentes con generación automática, y dashboard con gráficas y estadísticas.
          La demo incluye un usuario showcase con datos de ejemplo reales.
        </p>

        <div class="project-tech">
          <span>React 18</span>
          <span>TypeScript</span>
          <span>Vite</span>
          <span>Spring Boot 3</span>
          <span>Java 21</span>
          <span>PostgreSQL</span>
          <span>Flyway</span>
          <span>Railway</span>
        </div>

        <div class="highlights">
          <div class="highlight">
            <span class="mono num">01</span>
            <span>71 tests: 50 en backend (JUnit 5, Mockito, MockMvc) y 21 en frontend (Vitest, Testing Library)</span>
          </div>
          <div class="highlight">
            <span class="mono num">02</span>
            <span>JWT con userId extraído siempre del token, nunca del body de la petición</span>
          </div>
          <div class="highlight">
            <span class="mono num">03</span>
            <span>Presupuestos mensuales con alertas por color según el porcentaje consumido</span>
          </div>
          <div class="highlight">
            <span class="mono num">04</span>
            <span>Recurrentes con generación automática lazy al entrar en cada mes</span>
          </div>
        </div>
      </div>
    </div>

    <div class="project-card">
      <div class="card-accent" aria-hidden="true"></div>

      <div class="card-body">
        <div class="project-header">
          <div>
            <span class="project-type mono">Proyecto personal en producción</span>
            <h3 class="project-name">Efeméride Diaria</h3>
            <p class="project-tagline">Cada día un evento histórico. Adivina el año.</p>
          </div>
          <div class="project-links">
            <a
              href="https://efemeride.cristiansg.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-sm"
            >
              Demo en vivo ↗
            </a>
            <a
              href="https://github.com/CristianSG2/efemeride"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost btn-sm"
            >
              GitHub ↗
            </a>
          </div>
        </div>

        <p class="project-description">
          Juego web diario al estilo Wordle: un evento histórico real con foto y pista de texto,
          y tienes que adivinar en qué año ocurrió. El contenido se renueva cada día de forma
          automática, sin intervención manual y sin base de datos.
        </p>

        <div class="project-tech">
          <span>React 18</span>
          <span>TypeScript</span>
          <span>Vite</span>
          <span>Node</span>
          <span>GitHub Actions</span>
        </div>

        <div class="highlights">
          <div class="highlight">
            <span class="mono num">01</span>
            <span>Job diario por cron que consulta la API de Wikipedia y filtra por relevancia (pageviews) y calidad de imagen</span>
          </div>
          <div class="highlight">
            <span class="mono num">02</span>
            <span>Enmascarado de años en el texto de la pista para no hacer spoiler de la respuesta</span>
          </div>
          <div class="highlight">
            <span class="mono num">03</span>
            <span>Sin base de datos: los datos se sirven como JSON estático</span>
          </div>
          <div class="highlight">
            <span class="mono num">04</span>
            <span>Partida, racha y récord persistidos en localStorage; tests con Vitest</span>
          </div>
        </div>
      </div>
    </div>

    <div class="project-card">
      <div class="card-accent" aria-hidden="true"></div>

      <div class="card-body">
        <div class="project-header">
          <div>
            <span class="project-type mono">Proyecto personal en producción</span>
            <h3 class="project-name">rutameteo</h3>
            <p class="project-tagline">El tiempo por tramos en tu ruta.</p>
          </div>
          <div class="project-links">
            <a
              href="https://rutameteo.cristiansg.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-sm"
            >
              Demo en vivo ↗
            </a>
            <a
              href="https://github.com/CristianSG2/rutameteo"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost btn-sm"
            >
              GitHub ↗
            </a>
          </div>
        </div>

        <p class="project-description">
          Aplicación web que muestra el pronóstico del tiempo en cada tramo de tu ruta de
          conducción. Introduce origen, destino y hora de salida, y la app calcula la ruta real
          por carretera, estima la hora de llegada a cada punto y consulta el tiempo que hará
          allí a esa hora exacta.
        </p>

        <div class="project-tech">
          <span>Vue 3</span>
          <span>Vite</span>
          <span>Leaflet.js</span>
          <span>SCSS</span>
          <span>Open-Meteo API</span>
          <span>OSRM API</span>
        </div>

        <div class="highlights">
          <div class="highlight">
            <span class="mono num">01</span>
            <span>Ruta real por carretera con tiempos de llegada precisos tramo a tramo</span>
          </div>
          <div class="highlight">
            <span class="mono num">02</span>
            <span>Pronóstico del tiempo por tramo: temperatura, lluvia, viento y visibilidad</span>
          </div>
          <div class="highlight">
            <span class="mono num">03</span>
            <span>Autocompletado de direcciones con soporte de calles y puntos de interés</span>
          </div>
          <div class="highlight">
            <span class="mono num">04</span>
            <span>0 backends propios, 0 API keys — todo corre en el cliente</span>
          </div>
        </div>
      </div>
    </div>
    </div><!-- /projects-list -->
  </div>
</section>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  .card-accent {
    height: 2px;
    background: linear-gradient(90deg, var(--mauve), var(--blue), var(--teal));
  }

  .card-body {
    padding: 2.5rem 3rem;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }

  .project-type {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .project-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    background: linear-gradient(135deg, var(--mauve), var(--blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .project-tagline {
    color: var(--subtext0);
    font-size: 1rem;
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
    align-items: flex-start;
    padding-top: 0.25rem;
  }

  .project-description {
    color: var(--subtext1);
    font-size: 1.05rem;
    line-height: 1.78;
    margin-bottom: 1.75rem;
    max-width: 820px;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .project-tech span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    padding: 0.28rem 0.75rem;
    border-radius: 100px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    color: var(--subtext1);
  }

  .highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }

  .highlight {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    font-size: 0.9rem;
    color: var(--subtext1);
    line-height: 1.55;
  }

  .num {
    color: var(--accent);
    font-size: 0.78rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  @media (max-width: 640px) {
    .card-body { padding: 1.75rem 1.5rem; }
  }
</style>
