---
const codeSnippet = `<span style="color:var(--overlay0)">// app/Models/Book.php</span>

<span style="color:var(--mauve)">namespace</span> App\\Models;

<span style="color:var(--mauve)">use</span> Illuminate\\Database\\Eloquent\\Model;
<span style="color:var(--mauve)">use</span> Illuminate\\Database\\Eloquent\\SoftDeletes;

<span style="color:var(--mauve)">class</span> Book <span style="color:var(--mauve)">extends</span> Model
&#123;
    <span style="color:var(--mauve)">protected</span> <span style="color:var(--peach)">$fillable</span> = [
        <span style="color:var(--green)">'title'</span>, <span style="color:var(--green)">'author'</span>,
        <span style="color:var(--green)">'isbn'</span>, <span style="color:var(--green)">'cover_url'</span>,
    ];

    <span style="color:var(--mauve)">public function</span> <span style="color:var(--blue)">reviews</span>()
    &#123;
        <span style="color:var(--mauve)">return</span> <span style="color:var(--peach)">$this</span>-&gt;<span style="color:var(--blue)">hasMany</span>(Review::<span style="color:var(--mauve)">class</span>);
    &#125;
&#125;`;
---

<section id="inicio" class="hero">
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>

  <div class="container">
    <div class="hero-grid">

      <!-- Left: content -->
      <div class="hero-content">
        <p class="hero-label mono">Hola, soy</p>

        <h1 class="hero-name">
          Cristian<br />
          <em>Sánchez</em><br />
          Gutiérrez
        </h1>

        <p class="hero-role mono">Junior Web Developer</p>

        <div class="hero-tags">
          <span>PHP</span>
          <span>Laravel</span>
          <span>JavaScript</span>
          <span>PostgreSQL</span>
          <span>Docker</span>
        </div>

        <div class="hero-ctas">
          <a href="#proyectos" class="btn btn-primary">Ver proyectos</a>
          <a href="#contacto" class="btn btn-ghost">Contacto</a>
        </div>
      </div>

      <!-- Right: fake terminal -->
      <div class="terminal-wrapper" aria-hidden="true">
        <div class="term-bar">
          <span class="dot" style="background:#f38ba8;"></span>
          <span class="dot" style="background:#f9e2af;"></span>
          <span class="dot" style="background:#a6e3a1;"></span>
          <span class="term-title">~/ReadOn/app/Models/Book.php</span>
        </div>
        <div class="term-body">
          <pre><code id="termCode" set:html={codeSnippet}></code></pre>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 64px;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.12;
    pointer-events: none;
  }
  .orb-1 {
    width: 650px;
    height: 650px;
    background: var(--mauve);
    top: -180px;
    right: -120px;
    animation: drift 14s ease-in-out infinite alternate;
  }
  .orb-2 {
    width: 450px;
    height: 450px;
    background: var(--blue);
    bottom: -120px;
    left: -100px;
    animation: drift 10s ease-in-out infinite alternate-reverse;
  }

  @keyframes drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(50px, -40px) scale(1.08); }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    gap: 6rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    min-width: 0;
  }

  .hero-label {
    font-size: 0.88rem;
    color: var(--subtext0);
    margin-bottom: 1rem;
    letter-spacing: 0.08em;
    animation: fadeUp 0.7s ease both;
  }

  .hero-name {
    font-size: clamp(3rem, 7vw, 6.5rem);
    font-weight: 800;
    line-height: 0.92;
    margin-bottom: 1.75rem;
    animation: fadeUp 0.7s 0.1s ease both;
  }

  .hero-name em {
    font-style: italic;
    font-weight: 300;
    background: linear-gradient(135deg, var(--mauve) 0%, var(--blue) 60%, var(--teal) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-role {
    font-size: 0.95rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 1.75rem;
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.75rem;
    animation: fadeUp 0.7s 0.3s ease both;
  }

  .hero-tags span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--subtext1);
    background: var(--bg-subtle);
    letter-spacing: 0.06em;
  }

  .hero-ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    animation: fadeUp 0.7s 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Terminal */
  .terminal-wrapper {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    min-width: 0;
    animation: fadeUp 0.7s 0.5s ease both;
  }

  .term-bar {
    background: var(--surface0);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 12px 12px 0 0;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }

  .term-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--subtext0);
    margin-left: 0.4rem;
  }

  .term-body {
    overflow: hidden;
    background: var(--mantle);
    border-radius: 0 0 12px 12px;
    padding: 1.25rem;
    max-height: 420px;
    mask-image: linear-gradient(to bottom, transparent 0%, black 18%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 18%);
  }

  .term-body pre {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.7;
  }

  .term-body code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    line-height: 1.7;
    color: var(--text);
    white-space: pre;
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .terminal-wrapper { display: none; }
  }
</style>

<script>
  const el = document.getElementById('termCode');
  if (el) {
    const lines = el.innerHTML.split('\n');
    el.innerHTML = '';
    lines.forEach((line, i) => {
      setTimeout(() => {
        el.innerHTML += (i === 0 ? '' : '\n') + line;
      }, i * 250);
    });
  }
</script>
